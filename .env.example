# =============================================================================
# APCD Portal - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Lines marked [REQUIRED] must be set for the app to start.
# Lines marked [REQUIRED IN PRODUCTION] must be set when NODE_ENV=production.
# Lines marked [OPTIONAL] have sane defaults or are disabled features.
#
# Generate secrets with:  openssl rand -base64 64
# Generate VAPID keys:    npx web-push generate-vapid-keys
# =============================================================================

# ---- General ----
NODE_ENV=                              # [REQUIRED] "development" or "production"
PORT=                                  # [OPTIONAL] API port (default: 4000)
APP_NAME=                              # [OPTIONAL] Display name (default: "APCD Empanelment Portal")
APP_URL=                               # [REQUIRED] Frontend URL for CORS (e.g., https://apcd.example.com). Comma-separated for multiple origins.
API_URL=                               # [REQUIRED] Backend API URL, used by Next.js server-side proxy (e.g., http://api:4000 in Docker, http://localhost:4000 locally)
PORTAL_URL=                            # [OPTIONAL] Public portal URL for certificate QR codes (defaults to APP_URL)

# ---- Database (PostgreSQL) ----
DATABASE_URL=                          # [REQUIRED] Full connection string. Append &connection_limit=20 for pool sizing (e.g., postgresql://user:pass@host:5432/dbname?schema=public&connection_limit=20)
DATABASE_HOST=                         # [OPTIONAL] Used by docker-compose only
DATABASE_PORT=                         # [OPTIONAL] Used by docker-compose only
DATABASE_USER=                         # [OPTIONAL] Used by docker-compose only
DATABASE_PASSWORD=                     # [OPTIONAL] Used by docker-compose only
DATABASE_NAME=                         # [OPTIONAL] Used by docker-compose only
POSTGRES_USER=                         # [OPTIONAL] Docker PostgreSQL container user
POSTGRES_PASSWORD=                     # [OPTIONAL] Docker PostgreSQL container password
POSTGRES_DB=                           # [OPTIONAL] Docker PostgreSQL container database name

# ---- Redis ----
REDIS_URL=                             # [OPTIONAL] Redis connection URL (e.g., redis://localhost:6379)
REDIS_HOST=                            # [OPTIONAL] Redis hostname
REDIS_PORT=                            # [OPTIONAL] Redis port

# ---- JWT Authentication ----
JWT_SECRET=                            # [REQUIRED] Secret for signing access tokens. Min 64 chars in production.
JWT_ACCESS_EXPIRY=                     # [OPTIONAL] Access token TTL (default: "15m")
JWT_REFRESH_SECRET=                    # [REQUIRED] Secret for signing refresh tokens. Min 64 chars in production.
JWT_REFRESH_EXPIRY=                    # [OPTIONAL] Refresh token TTL (default: "7d")

# ---- NextAuth (Frontend session) ----
NEXTAUTH_URL=                          # [REQUIRED] Must match APP_URL (e.g., https://apcd.example.com)
NEXTAUTH_SECRET=                       # [REQUIRED] Secret for NextAuth session encryption. Min 32 chars.

# ---- MinIO / S3-compatible Object Storage ----
MINIO_ENDPOINT=                        # [REQUIRED] MinIO server hostname (e.g., "localhost" or "minio")
MINIO_PORT=                            # [OPTIONAL] MinIO API port (default: 9000)
MINIO_ACCESS_KEY=                      # [REQUIRED] MinIO access key / username
MINIO_SECRET_KEY=                      # [REQUIRED] MinIO secret key / password
MINIO_BUCKET=                          # [OPTIONAL] S3 bucket name (default: "apcd-documents")
MINIO_USE_SSL=                         # [OPTIONAL] Use SSL for MinIO (default: false)
MINIO_CONSOLE_PORT=                    # [OPTIONAL] MinIO console UI port (default: 9001)
STORAGE_TYPE=                          # [OPTIONAL] "minio" (default) or "local" for filesystem fallback
LOCAL_STORAGE_PATH=                    # [OPTIONAL] Filesystem path when STORAGE_TYPE=local

# ---- Razorpay Payment Gateway ----
RAZORPAY_KEY_ID=                       # [REQUIRED] Razorpay API key ID (rzp_test_* for test, rzp_live_* for production)
RAZORPAY_KEY_SECRET=                   # [REQUIRED] Razorpay API secret key
RAZORPAY_WEBHOOK_SECRET=               # [OPTIONAL] Webhook signature verification secret
NEXT_PUBLIC_RAZORPAY_KEY=              # [OPTIONAL] Public Razorpay key for browser checkout (falls back to API response)

# ---- Email / SMTP (legacy — used by notification system) ----
SMTP_ENABLED=                          # [OPTIONAL] Enable email sending (default: false)
SMTP_HOST=                             # [REQUIRED if SMTP_ENABLED=true] SMTP server hostname
SMTP_PORT=                             # [OPTIONAL] SMTP port (default: 587)
SMTP_SECURE=                           # [OPTIONAL] Use TLS (default: false)
SMTP_USER=                             # [REQUIRED if SMTP_ENABLED=true] SMTP username
SMTP_PASS=                             # [REQUIRED if SMTP_ENABLED=true] SMTP password
SMTP_FROM=                             # [OPTIONAL] From address (default: noreply@apcd.npc.gov.in)

# ---- SMS (mobile OTP verification) ----
SMS_PROVIDER=                          # [REQUIRED for mobile verification] "msg91" (GoI-approved) or "fast2sms". Set to "none" or leave empty to disable.
MSG91_AUTH_KEY=                        # [REQUIRED if SMS_PROVIDER=msg91] MSG91 auth key
MSG91_TEMPLATE_ID=                     # [REQUIRED if SMS_PROVIDER=msg91] MSG91 OTP template ID
FAST2SMS_API_KEY=                      # [REQUIRED if SMS_PROVIDER=fast2sms] Fast2SMS API key

# ---- Push Notifications (Web Push / VAPID) ----
VAPID_PUBLIC_KEY=                      # [OPTIONAL] VAPID public key for web push
VAPID_PRIVATE_KEY=                     # [OPTIONAL] VAPID private key for web push
VAPID_SUBJECT=                         # [OPTIONAL] VAPID subject (e.g., mailto:admin@apcd.gov.in)

# ---- File Upload Limits ----
MAX_FILE_SIZE_MB=                      # [OPTIONAL] Max individual file size in MB (default: 10)
MAX_TOTAL_UPLOAD_MB=                   # [OPTIONAL] Max total upload per application in MB (default: 100)

# ---- Rate Limiting ----
THROTTLE_TTL=                          # [OPTIONAL] Rate limit window in seconds (default: 60)
THROTTLE_LIMIT=                        # [OPTIONAL] Max requests per window (default: 100)

# ---- Data Seeding (development/CI only) ----
SEED_SECRET=                           # [OPTIONAL] Secret to protect test password reset endpoint. Must be set explicitly — no default in production.

# ---- Frontend-only ----
NEXT_PUBLIC_API_URL=                   # [OPTIONAL] API URL for browser-side calls (uses Next.js rewrites if empty)
NEXT_PUBLIC_ENABLE_SW=                 # [OPTIONAL] Force service worker registration in development (default: false)
NEXT_TELEMETRY_DISABLED=               # [OPTIONAL] Disable Next.js telemetry (set to 1)

# ---- SSL/TLS (for nginx reverse proxy in docker-compose.prod.yml) ----
SSL_CERT_PATH=                         # [OPTIONAL] Path to SSL certificate file
SSL_KEY_PATH=                          # [OPTIONAL] Path to SSL private key file

# ---- Monitoring (self-hosted) ----
# Use Grafana + Prometheus + Loki for monitoring on NICSI VM
